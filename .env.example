# Ethos integration credentials. Copy to .env.local and fill in.
# .env.local is gitignored — never commit your real values.
#
# The Next.js dev server must be restarted after changing env vars.

# Canonical Ethos origin. Should always be https://www.ethos.do unless
# you're pointed at a staging deployment.
ETHOS_BASE_URL=https://www.ethos.do

# Site-scoped API key from the Ethos dashboard: Mi Sitio Web → Crear
# clave nueva. Format: ethos_live_<64 hex chars> (75 chars total).
# Shown only once — if lost, create a new one.
#
# Required scopes (or wildcard *):
#   site:read, menu:read,
#   reservations:write, takeouts:write,
#   customers:write, events:write
ETHOS_API_KEY=

# Optional. Canonical public URL of the deployed site. Used for
# metadataBase so og:image resolves to absolute URLs in social cards.
# Vercel auto-sets a workable VERCEL_URL if you leave this blank, but
# pinning the canonical URL here avoids preview URLs leaking into
# production OG cards.
# NEXT_PUBLIC_SITE_URL=https://restaurant.example.com
